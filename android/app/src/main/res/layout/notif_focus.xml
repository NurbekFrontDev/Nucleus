<?xml version="1.0" encoding="utf-8"?>
<!--
  Кастомная раскладка постоянного уведомления таймера Помодоро.
  Слева: название фазы и подпись. Справа: крупный обратный отсчёт mm:ss
  (как в GoodTime). Текст рисуем сами через RemoteViews, поэтому отсчёт виден
  на любой прошивке, включая MIUI/HyperOS, где системный хронометр не работает.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="2dp"
    android:paddingBottom="2dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/notif_focus_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Compat.Notification.Title"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/notif_focus_sub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Compat.Notification.Info"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <TextView
        android:id="@+id/notif_focus_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginLeft="12dp"
        android:textAppearance="@style/TextAppearance.Compat.Notification.Title"
        android:textStyle="bold"
        android:textSize="26sp"
        android:includeFontPadding="false" />
</LinearLayout>
