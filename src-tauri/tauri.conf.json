{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nucleus",
  "version": "0.1.11",
  "identifier": "com.nucleus.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Nucleus",
        "width": 1100,
        "height": 800,
        "minWidth": 380,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://ewgrcmswwvbtoxdxkvuv.supabase.co/storage/v1/object/public/releases/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlGNjRFQzQxRDQ5NjZEREIKUldUYmJaYlVRZXhrbjdKdVVvMitkeWt2RTNlZGY4RE5rV1l5MlYxeEd5Vlo3TTBjT1BvYlJSdGIK"
    },
    "deep-link": {
      "desktop": {
        "schemes": ["com.nucleus.app"]
      }
    }
  }
}
